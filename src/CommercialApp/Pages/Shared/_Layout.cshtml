<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - CommsDrive</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet" integrity="sha384-QWTKZyjpPEjISv5WaRU9OFeRpok6YctnYmDr5pNlyT2bRjXh0JMhjY6hW+ALEwIH" crossorigin="anonymous">
    <style>
        :root { --gh-dark: #24292e; --gh-dark2: #2f363d; --azure: #0078d4; --azure-light: #50e6ff; --green: #2ea44f; }
        body { background: #f6f8fa; }
        .navbar { background: var(--gh-dark) !important; border-bottom: 1px solid #444d56; }
        .navbar-brand, .navbar-nav .nav-link { color: #fff !important; }
        .navbar-nav .nav-link:hover { color: var(--azure-light) !important; }
        .btn-primary { background: var(--azure); border-color: var(--azure); }
        .btn-primary:hover { background: #005a9e; border-color: #005a9e; }
        .btn-success-cd { background: var(--green); border-color: var(--green); color: #fff; border-radius: 6px; font-weight: 600; }
        .btn-success-cd:hover { background: #238636; border-color: #238636; color: #fff; }
        .hero { background: linear-gradient(135deg, var(--gh-dark) 0%, #1b2a3b 100%); color: #fff; padding: 6rem 0 4rem; }
        .section-light { background: #fff; padding: 4rem 0; border-top: 1px solid #e1e4e8; }
        .section-grey { background: #f6f8fa; padding: 4rem 0; border-top: 1px solid #e1e4e8; }
        .pricing-card { background: #fff; border: 1px solid #e1e4e8; border-radius: 8px; padding: 2rem; height: 100%; }
        .pricing-card.featured { border: 2px solid var(--azure); box-shadow: 0 4px 20px rgba(0,120,212,0.15); }
        .pricing-card .price { font-size: 2.5rem; font-weight: 700; color: var(--gh-dark); }
        .pricing-card .price span { font-size: 1rem; font-weight: 400; color: #6a737d; }
        .feature-icon { width: 48px; height: 48px; border-radius: 8px; background: var(--azure); display: flex; align-items: center; justify-content: center; margin-bottom: 1rem; }
        footer { background: var(--gh-dark); color: #959da5; border-top: 1px solid #444d56; padding: 2rem 0; }
        footer a { color: #959da5; text-decoration: none; }
        footer a:hover { color: var(--azure-light); }
        .check-list li::before { content: "✓ "; color: var(--green); font-weight: 700; }
        .check-list { list-style: none; padding: 0; }
        .check-list li { padding: 0.25rem 0; }
    </style>
</head>
<body>
    <nav class="navbar navbar-expand-lg navbar-dark">
        <div class="container-xl">
            <a class="navbar-brand fw-bold" asp-page="/Index">
                <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="#50e6ff" stroke-width="2" style="margin-right:6px;vertical-align:-3px"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07A19.5 19.5 0 0 1 4.69 14 19.79 19.79 0 0 1 1.61 5.37 2 2 0 0 1 3.6 3h3a2 2 0 0 1 2 1.72c.127.96.361 1.903.7 2.81a2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l.81-.81a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 17z"/></svg>
                CommsDrive
            </a>
            <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarMain">
                <span class="navbar-toggler-icon"></span>
            </button>
            <div class="collapse navbar-collapse" id="navbarMain">
                <ul class="navbar-nav me-auto">
                    <li class="nav-item"><a class="nav-link" asp-page="/Index">Home</a></li>
                    <li class="nav-item"><a class="nav-link" asp-page="/Features/Index">Features</a></li>
                    <li class="nav-item"><a class="nav-link" asp-page="/Pricing/Index">Pricing</a></li>
                </ul>
                <ul class="navbar-nav">
                    <li class="nav-item"><a class="nav-link" asp-page="/GetStarted/Index">Get Started</a></li>
                    @if (User.Identity?.IsAuthenticated == true)
                    {
                        <li class="nav-item"><a class="nav-link" asp-page="/Dashboard/Index">Dashboard</a></li>
                        <li class="nav-item">
                            <form method="post" action="/MicrosoftIdentity/Account/SignOut" style="display:inline">
                                <button type="submit" class="btn btn-sm btn-outline-light ms-2">Sign Out</button>
                            </form>
                        </li>
                    }
                    else
                    {
                        <li class="nav-item"><a class="btn btn-sm btn-success-cd ms-2" asp-page="/GetStarted/Index">Start Free</a></li>
                    }
                </ul>
            </div>
        </div>
    </nav>
    <main>@RenderBody()</main>
    <footer>
        <div class="container-xl">
            <div class="row">
                <div class="col-md-4 mb-3">
                    <p class="fw-bold text-white mb-1">CommsDrive</p>
                    <p class="small mb-0">AI-powered communications platform built on Azure.</p>
                </div>
                <div class="col-md-4 mb-3">
                    <p class="fw-semibold text-white mb-1 small">Product</p>
                    <a asp-page="/Features/Index" class="d-block small">Features</a>
                    <a asp-page="/Pricing/Index" class="d-block small">Pricing</a>
                    <a asp-page="/GetStarted/Index" class="d-block small">Get Started</a>
                </div>
                <div class="col-md-4 text-md-end">
                    <p class="small mb-0">&copy; @DateTime.Now.Year CommsDrive. All rights reserved.</p>
                    <a asp-page="/Privacy" class="small">Privacy Policy</a>
                </div>
            </div>
        </div>
    </footer>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js" integrity="sha384-YvpcrYf0tY3lHB60NNkmXc4s9bIOgUxi8T/jzmVBdRf8A9M3lY5J7SVQK4LhKp2B" crossorigin="anonymous"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>

